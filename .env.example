APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=bandarafrozen
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"


# Bandara Credit / Rewards
# Production earn posting requires: ENABLED=true, SHADOW_MODE=false, EARN_ENABLED=true, AUTO_POST_ENABLED=true.
# Keep REDEEM_ENABLED=false until checkout redemption/reservation is built and tested.
BANDARA_CREDIT_ENABLED=false
BANDARA_CREDIT_SHADOW_MODE=true
BANDARA_CREDIT_EARN_ENABLED=false
BANDARA_CREDIT_REDEEM_ENABLED=false
BANDARA_CREDIT_AUTO_POST_ENABLED=false
BANDARA_CREDIT_REPEAT_BONUS_ENABLED=true
BANDARA_CREDIT_WELCOME_BONUS_ENABLED=true
BANDARA_CREDIT_BIRTHDAY_ENABLED=true
BANDARA_CREDIT_TIERS_ENABLED=true
BANDARA_CREDIT_ELIGIBILITY_MODE=role
BANDARA_CREDIT_ELIGIBILITY_COLUMN=customer_type
BANDARA_CREDIT_ELIGIBILITY_B2C_VALUE=b2c
BANDARA_CREDIT_PER_AMOUNT_SPENT=100
BANDARA_CREDIT_AMOUNT_PER_BLOCK=1
BANDARA_CREDIT_REPEAT_WINDOW_DAYS=10
BANDARA_CREDIT_WELCOME_AMOUNT=100
BANDARA_CREDIT_WELCOME_MIN_ORDER_VALUE=999
BANDARA_CREDIT_SILVER_THRESHOLD=0
BANDARA_CREDIT_GOLD_THRESHOLD=10000
BANDARA_CREDIT_PLATINUM_THRESHOLD=25000
BANDARA_CREDIT_SILVER_BIRTHDAY=100
BANDARA_CREDIT_GOLD_BIRTHDAY=150
BANDARA_CREDIT_PLATINUM_BIRTHDAY=200
BANDARA_CREDIT_NEXT_REWARD_AT=500
BANDARA_CREDIT_HISTORY_LIMIT=8
BANDARA_CREDIT_REDEEM_MINIMUM_POINTS=500
BANDARA_CREDIT_POINT_VALUE=1

# B2B pricing
# Default true: active products without explicit B2B pricing still appear/order using base price, never B2C-only specials.
B2B_ALLOW_RETAIL_PRICE_FALLBACK=true
DEFAULT_GST_RATE=5
FALLBACK_MISSING_PRODUCT_GST_RATE=true
B2B_FORCE_DEFAULT_GST_WHEN_ZERO_RATE=true

# Delivery / cold-chain handling
STORE_PINCODE=411001
DELIVERY_REQUIRE_SERVICEABLE_PINCODE=false
DELIVERY_TAX_RATE=0
HANDLING_TAX_RATE=0
DELIVERY_HANDLING_TEMPERATURE_MODE=frozen

# Distance-based delivery fees
# Google is the active hosted distance provider. Customer latitude/longitude is optional;
# if present, Google calculates distance from coordinates, otherwise it uses the address text.
DELIVERY_DISTANCE_ENABLED=false
DELIVERY_DISTANCE_PROVIDER=google
DELIVERY_DISTANCE_REQUIRED=false
DELIVERY_DISTANCE_FALLBACK_TO_ZONE=true
DELIVERY_DISTANCE_TIMEOUT_SECONDS=6
STORE_DELIVERY_ORIGIN_ADDRESS="402B, Nityanand Complex, Narangi Baug Road, Pune 411001"
STORE_DELIVERY_ORIGIN_LAT=18.5358492
STORE_DELIVERY_ORIGIN_LNG=73.8798846
GOOGLE_MAPS_API_KEY=
GOOGLE_DISTANCE_MATRIX_API_KEY=
GOOGLE_MAPS_DISTANCE_MATRIX_API_KEY=
GOOGLE_GEOCODING_API_KEY=
