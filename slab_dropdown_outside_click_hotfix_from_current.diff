+
+            document.addEventListener('toggle', function (event) {
+                var menu = event.target;
+                if (!menu || menu.tagName !== 'DETAILS' || !menu.classList || !menu.classList.contains('js-slab-band-menu') || !menu.open) {
+                    return;
+                }
+
+                closeOpenSlabMenus(menu);
+            }, true);
+
+            document.addEventListener('keydown', function (event) {
